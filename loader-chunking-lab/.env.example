# ──────────────────────────────────────────────────────────────────
# .env.example — copy thành .env và điền API key vào
# ──────────────────────────────────────────────────────────────────

# OpenAI (cần cho: semantic chunking với OpenAI model, contextual chunking)
OPENAI_API_KEY=sk-...

# Anthropic (cần cho: contextual chunking với Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Google (cần cho: semantic chunking với Gemini Embedding)
GOOGLE_API_KEY=AI...

# Cohere (cần cho: semantic chunking với Cohere Embed)
COHERE_API_KEY=...

# Voyage AI (cần cho: semantic chunking với Voyage)
VOYAGE_API_KEY=pa-...

# Jina AI (cần cho: semantic chunking với Jina)
JINA_API_KEY=jina_...

# HuggingFace (cần cho: model gated như Llama)
HF_TOKEN=hf_...
